# Copy this file to `.env` (in the deploy/ directory) on the server and fill in values.
# docker compose automatically loads deploy/.env when run from the deploy/ directory.
#
# Generate a strong JWT private key, e.g.:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Paste the full PEM as a single value (use quotes; keep the BEGIN/END lines).
# IMPORTANT: keep this value secret and stable — changing it invalidates all issued tokens.
OCT_JWT_PRIVATE_KEY=

# Display name for who runs this server (shown to users).
OCT_SERVER_OWNER=Libr

# Comma-separated list of allowed browser origins for CORS.
# Set to your public URL. Leave blank to allow all (*) — not recommended for prod.
OCT_CORS_ALLOWED_ORIGINS=https://oct.dev.libr.live
